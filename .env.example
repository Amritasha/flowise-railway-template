# Core (required)
PORT=3000
NODE_ENV=production

# Auth — set both to enable login (recommended for production)
FLOWISE_USERNAME=admin
FLOWISE_PASSWORD=                  # Set a strong password

# Storage paths (pre-configured in railway.toml)
DATABASE_PATH=/root/.flowise
APIKEY_PATH=/root/.flowise
SECRETKEY_PATH=/root/.flowise
LOG_PATH=/root/.flowise/logs
BLOB_STORAGE_PATH=/root/.flowise/storage

# Optional: use PostgreSQL instead of SQLite
# DATABASE_TYPE=postgres
# DATABASE_HOST=
# DATABASE_PORT=5432
# DATABASE_NAME=flowise
# DATABASE_USER=
# DATABASE_PASSWORD=
# DATABASE_SSL=true

# Optional: Redis for queue mode (high-load deployments)
# MODE=queue
# REDIS_URL=${{Redis.REDIS_URL}}

# Optional: S3 for file storage instead of local volume
# STORAGE_TYPE=s3
# S3_STORAGE_BUCKET_NAME=
# S3_STORAGE_ACCESS_KEY_ID=
# S3_STORAGE_SECRET_ACCESS_KEY=
# S3_STORAGE_REGION=us-east-1

# Optional: Email for password reset
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_SECURE=false
# SENDER_EMAIL=noreply@example.com

# Optional: Security
DISABLE_FLOWISE_TELEMETRY=true
FLOWISE_FILE_SIZE_LIMIT=50mb
NUMBER_OF_PROXIES=1
